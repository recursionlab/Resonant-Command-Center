# Environment Variables for Resonant Command Center
# Copy this file to .env.local and fill in your values

# Google Gemini API Key (for Gemini features)
VITE_GEMINI_API_KEY=your_gemini_key_here
# OpenRouter API Key (for LLM chat, analysis, and ingestion)
VITE_OPENROUTER_API_KEY=your_openrouter_key_here
# OpenRouter Model (default: stepfun/step-3.5-flash)
VITE_OPENROUTER_MODEL=stepfun/step-3.5-flash
